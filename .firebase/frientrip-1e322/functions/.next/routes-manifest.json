        "nxtPtripId": "nxtPtripId"
      },
      "namedRegex": "^/trips/(?<nxtPtripId>[^/]+?)/house\\-details(?:/)?$"
    },
    {
      "page": "/trips/[tripId]/invite",
      "regex": "^/trips/([^/]+?)/invite(?:/)?$",
      "routeKeys": {
        "nxtPtripId": "nxtPtripId"
      },
      "namedRegex": "^/trips/(?<nxtPtripId>[^/]+?)/invite(?:/)?$"
    },
    {
      "page": "/trips/[tripId]/manage",
      "regex": "^/trips/([^/]+?)/manage(?:/)?$",
      "routeKeys": {
        "nxtPtripId": "nxtPtripId"
      },
      "namedRegex": "^/trips/(?<nxtPtripId>[^/]+?)/manage(?:/)?$"
    },
    {
      "page": "/trips/[tripId]/member-payment",
      "regex": "^/trips/([^/]+?)/member\\-payment(?:/)?$",
      "routeKeys": {
        "nxtPtripId": "nxtPtripId"
      },
