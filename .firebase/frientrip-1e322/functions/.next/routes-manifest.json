{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/trips/[tripId]",
      "regex": "^/trips/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtripId": "nxtPtripId"
      },
      "namedRegex": "^/trips/(?<nxtPtripId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/trips/[tripId]/carpool",
      "regex": "^/trips/([^/]+?)/carpool(?:/)?$",
      "routeKeys": {
        "nxtPtripId": "nxtPtripId"
      },
      "namedRegex": "^/trips/(?<nxtPtripId>[^/]+?)/carpool(?:/)?$"
    },
    {
      "page": "/trips/[tripId]/expenses",
